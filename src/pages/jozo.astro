---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import JozoHero from "../components/jozo/JozoHero.astro";
import JozoCapabilities from "../components/jozo/JozoCapabilities.astro";
import JozoAchievements from "../components/jozo/JozoAchievements.astro";
import JozoLimits from "../components/jozo/JozoLimits.astro";
import JozoTeaserRecepcia from "../components/jozo/JozoTeaserRecepcia.astro";
import JozoComingSoon from "../components/jozo/JozoComingSoon.astro";
import Footer from "../components/Footer.astro";
import { SITE } from "../config/site.mjs";
// deploy-ping: jozo page refresh
---
<Layout
  title="Jožo | AI operátor pre exekúciu a workflowy"
  description="Jožo je AI operátor postavený na OpenClaw: tasky, operatíva, workflowy a reporting. Praktická exekúcia namiesto chatbota na efekt."
>
  <Header />
  <main id="main-content" role="main">
    <JozoHero />
    <JozoAchievements />
    <JozoCapabilities />
    <JozoLimits />
    <JozoTeaserRecepcia />
    <JozoComingSoon />
  </main>
  <Footer />

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: 'Jožo – AI operátor',
    url: `${SITE.url}/jozo`,
    description: 'Jožo je AI operátor postavený na OpenClaw: tasky, operatíva, workflowy a reporting.'
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'Čo Jožo robí autonómne?',
        acceptedAnswer: { '@type': 'Answer', text: 'Bežné tasky, poznámky, workflowy a reporting.' }
      },
      {
        '@type': 'Question',
        name: 'Kedy treba potvrdenie od človeka?',
        acceptedAnswer: { '@type': 'Answer', text: 'Pri citlivých akciách, externej komunikácii a platbách.' }
      },
      {
        '@type': 'Question',
        name: 'Nahrádza Jožo medicínske rozhodovanie?',
        acceptedAnswer: { '@type': 'Answer', text: 'Nie. Medicínske rozhodnutia zostávajú výlučne na lekárovi.' }
      }
    ]
  })} />
</Layout>
