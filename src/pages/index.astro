---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import HeroGrid from "../components/home/HeroGrid.astro";
import Footer from "../components/Footer.astro";
import { SITE } from "../config/site.mjs";
---

<Layout
  title="AI recepcia pre ambulancie | jozef.xvadur"
  description="Pomáham ambulanciám znížiť počet zmeškaných hovorov a zrýchliť objednávanie pacientov cez AI recepciu a booking flow."
  canonicalURL={SITE.url}
>
  <Header />
  <main id="main-content" role="main">
    <HeroGrid />
  </main>
  <Footer />

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'ProfessionalService',
    name: 'jozef.xvadur',
    url: SITE.url,
    areaServed: 'Slovakia',
    serviceType: 'AI recepcia pre ambulancie',
    description: 'AI recepcia pre ambulancie: menej zmeškaných hovorov, rýchlejší booking a menej chaosu na linke.',
    contactPoint: [{
      '@type': 'ContactPoint',
      contactType: 'sales',
      email: 'adam@xvadur.com'
    }]
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'Koľko trvá pilot?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Typicky 7–14 dní od úvodného callu po prvé ostré testy.'
        }
      },
      {
        '@type': 'Question',
        name: 'Musím meniť celý systém?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Nie. Začíname pilotom nad tým, čo už používate, a napájame to postupne.'
        }
      },
      {
        '@type': 'Question',
        name: 'Pre koho je to vhodné?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Pre ambulancie a služby, kde hovory a objednávky preťažujú personál.'
        }
      }
    ]
  })} />
</Layout>
