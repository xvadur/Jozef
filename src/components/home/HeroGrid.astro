---
import BrutalistButton from "../ui/BrutalistButton.astro";
import AnimatedBlock from "../ui/AnimatedBlock.tsx";
---

<section class="max-w-7xl mx-auto px-6 py-12">
  <!-- Asymmetric grid -->
  <div
    class="hero-grid grid gap-3"
    style="grid-template-columns: 1fr 1fr 280px; grid-template-rows: auto auto auto;"
  >
    <!-- Hero block: col 1-2, row 1 -->
    <AnimatedBlock client:load delay={0} className="col-span-2">
      <div
        class="p-10 flex flex-col justify-between min-h-[260px] h-full"
        style="border: var(--border-brutal); box-shadow: var(--shadow-brutal); background-color: var(--color-bg);"
      >
        <div>
          <p class="text-xs font-bold uppercase tracking-widest mb-3" style="color: var(--color-blue);">
            jozef.xvadur · Slovensko
          </p>
          <h1 class="text-5xl font-light leading-tight mb-4" style="color: var(--color-text);">
            AI recepcia pre ambulancie.<br />
            <span style="color: var(--color-blue);">Menej chaosu, viac vybavených pacientov.</span>
          </h1>
          <p class="text-lg font-light max-w-xl" style="color: var(--color-text); opacity: 0.72;">
            Nasadenie AI hlasového asistenta + booking flow do reálnej prevádzky.
            Cieľ je jednoduchý: menej zmeškaných hovorov, rýchlejšie objednávanie a voľnejšie ruky pre personál.
          </p>
        </div>
        <div class="flex gap-3 mt-6 flex-wrap">
          <BrutalistButton href="https://cal.com/xvadur" variant="blue" size="md" target="_blank">
            Rezervovať 20-min audit
          </BrutalistButton>
          <BrutalistButton href="/ai-recepcia" variant="white" size="md">
            Ako to funguje
          </BrutalistButton>
        </div>
      </div>
    </AnimatedBlock>

    <!-- Book a Call block: col 3, row 1 -->
    <AnimatedBlock client:load delay={0.1}>
      <div
        class="p-8 flex flex-col items-start justify-between min-h-[260px] h-full"
        style="border: var(--border-brutal); box-shadow: var(--shadow-brutal); background-color: #FF3EA5;"
      >
        <div>
          <p class="text-xs font-bold uppercase tracking-widest mb-2 text-white opacity-80">
            Porozprávajme sa
          </p>
          <h2 class="text-2xl font-bold text-white leading-tight">
            Rýchly<br />audit
          </h2>
        </div>
        <BrutalistButton
          href="https://cal.com/xvadur"
          variant="white"
          size="sm"
          target="_blank"
          class="mt-4"
        >
          Rezervovať →
        </BrutalistButton>
      </div>
    </AnimatedBlock>

    <!-- Service block: col 1, row 2 -->
    <AnimatedBlock client:load delay={0.2}>
      <div
        class="p-8 flex flex-col justify-between h-full"
        style="border: var(--border-brutal); box-shadow: var(--shadow-brutal); background-color: var(--color-silver);"
      >
        <p class="text-xs font-bold uppercase tracking-widest mb-2" style="color: var(--color-blue-deep);">
          Firma
        </p>
        <div>
          <h3 class="text-3xl font-bold mb-2">AI Recepcia</h3>
          <p class="text-sm font-light" style="opacity: 0.7;">
            Telefonický AI asistent pre ambulancie a služby.
            Preberie opakujúce sa hovory, predkvalifikuje a posunie booking ďalej.
          </p>
        </div>
      </div>
    </AnimatedBlock>

    <!-- What is Jožo block: col 2, row 2 -->
    <AnimatedBlock client:load delay={0.3}>
      <div
        class="p-8 flex flex-col justify-between h-full"
        style="border: var(--border-brutal); box-shadow: var(--shadow-brutal); background-color: var(--color-bg);"
      >
        <p class="text-xs font-bold uppercase tracking-widest mb-2" style="color: var(--color-blue-deep);">
          Môj AI suite
        </p>
        <div>
          <h3 class="text-2xl font-semibold mb-2">Kto je Jožo?</h3>
          <p class="text-sm font-light mb-4" style="opacity: 0.7;">
            Jožo je môj AI operátor postavený na OpenClaw.
            Pomáha mi s operatívou, obsahom a automatizáciami.
          </p>
          <a href="/jozo" class="text-sm font-bold uppercase tracking-wider hover:underline" style="color: var(--color-blue-deep);">
            Zistiť viac →
          </a>
        </div>
      </div>
    </AnimatedBlock>

    <!-- Jožo teaser block: col 3, row 2 -->
    <AnimatedBlock client:load delay={0.4}>
      <div
        class="p-8 flex flex-col justify-between h-full"
        style="border: var(--border-brutal); box-shadow: var(--shadow-brutal); background-color: var(--color-blue);"
      >
        <p class="text-xs font-bold uppercase tracking-widest mb-2 text-white opacity-80">
          Jožo
        </p>
        <p class="text-4xl" aria-hidden="true">🦞</p>
        <p class="text-sm font-bold text-white mt-2">
          OpenClaw · AI Suite
        </p>
      </div>
    </AnimatedBlock>

    <!-- Blog teaser: full width, row 3 -->
    <AnimatedBlock client:load delay={0.5} className="col-span-3">
      <div
        class="p-8 flex items-center justify-between h-full"
        style="border: var(--border-brutal); box-shadow: var(--shadow-brutal); background-color: var(--color-bg);"
      >
        <div>
          <p class="text-xs font-bold uppercase tracking-widest mb-1" style="color: var(--color-blue-deep);">
            Jožov denník
          </p>
          <h3 class="text-xl font-semibold">Builder blog z reálnej cesty</h3>
          <p class="text-sm font-light mt-1" style="opacity: 0.6;">Denné zápisky z budovania AI systémov, produktov a workflowov.</p>
        </div>
        <BrutalistButton href="/blog" variant="black" size="sm">
          Blog →
        </BrutalistButton>
      </div>
    </AnimatedBlock>
  </div>

  <!-- Trust strip -->
  <div class="trust-grid mt-4 grid gap-3" style="grid-template-columns: repeat(3, minmax(0, 1fr));">
    <div class="p-4" style="border: var(--border-brutal); box-shadow: var(--shadow-brutal-sm); background-color: var(--color-bg);">
      <p class="text-xs font-bold uppercase tracking-widest" style="color: var(--color-blue-deep);">Status</p>
      <p class="text-sm mt-1">Prvý pilot v príprave</p>
    </div>
    <div class="p-4" style="border: var(--border-brutal); box-shadow: var(--shadow-brutal-sm); background-color: var(--color-bg);">
      <p class="text-xs font-bold uppercase tracking-widest" style="color: var(--color-blue-deep);">Niche</p>
      <p class="text-sm mt-1">Healthcare-first prístup</p>
    </div>
    <div class="p-4" style="border: var(--border-brutal); box-shadow: var(--shadow-brutal-sm); background-color: var(--color-bg);">
      <p class="text-xs font-bold uppercase tracking-widest" style="color: var(--color-blue-deep);">Stack</p>
      <p class="text-sm mt-1">OpenClaw orchestrace + voice AI</p>
    </div>
  </div>

  <!-- Pain-first section -->
  <AnimatedBlock client:load delay={0.52}>
    <div class="mt-4 p-6 md:p-8" style="border: var(--border-brutal); box-shadow: var(--shadow-brutal); background-color: var(--color-bg);">
      <p class="text-xs font-bold uppercase tracking-widest mb-2" style="color: var(--color-blue-deep);">Ak toto bolí, sme fit</p>
      <h3 class="text-2xl md:text-3xl font-bold mb-3" style="color: var(--color-text);">Najčastejšie problémy na recepcii</h3>
      <div class="grid gap-3 md:gap-4 md:grid-cols-3 mt-4">
        <div class="p-4" style="border: var(--border-brutal); background: #fff;">
          <p class="text-sm font-bold">Zmeškané hovory</p>
          <p class="text-sm mt-1" style="opacity:0.75;">Pacient volá, nik nedvihne, dopyt sa stratí.</p>
        </div>
        <div class="p-4" style="border: var(--border-brutal); background: #fff;">
          <p class="text-sm font-bold">Preťažený personál</p>
          <p class="text-sm mt-1" style="opacity:0.75;">Sestry riešia telefón namiesto práce, ktorú majú robiť.</p>
        </div>
        <div class="p-4" style="border: var(--border-brutal); background: #fff;">
          <p class="text-sm font-bold">Chaos v bookingu</p>
          <p class="text-sm mt-1" style="opacity:0.75;">Ručné dohadovanie termínov brzdí celý deň.</p>
        </div>
      </div>
    </div>
  </AnimatedBlock>

  <!-- Social proof / pilot evidence -->
  <AnimatedBlock client:load delay={0.55}>
    <div class="mt-4 p-6 md:p-8" style="border: var(--border-brutal); box-shadow: var(--shadow-brutal); background-color: var(--color-silver);">
      <p class="text-xs font-bold uppercase tracking-widest mb-2" style="color: var(--color-blue-deep);">Pilot signal</p>
      <h3 class="text-2xl md:text-3xl font-bold mb-3" style="color: var(--color-text);">Staviame na reálnej prevádzke, nie na demo slidoch.</h3>
      <div class="grid gap-3 md:gap-4 md:grid-cols-3 mt-4">
        <div class="p-4" style="border: var(--border-brutal); background: var(--color-bg);">
          <p class="text-xs font-bold uppercase tracking-widest" style="color: var(--color-blue-deep);">Use case</p>
          <p class="text-sm mt-1">Inbound hovory + booking flow pre ambulancie</p>
        </div>
        <div class="p-4" style="border: var(--border-brutal); background: var(--color-bg);">
          <p class="text-xs font-bold uppercase tracking-widest" style="color: var(--color-blue-deep);">Execution</p>
          <p class="text-sm mt-1">Prompting, routing, test calls a iterácie v krátkych cykloch</p>
        </div>
        <div class="p-4" style="border: var(--border-brutal); background: var(--color-bg);">
          <p class="text-xs font-bold uppercase tracking-widest" style="color: var(--color-blue-deep);">Outcome</p>
          <p class="text-sm mt-1">Menej stratených kontaktov, lepšia dostupnosť pre pacientov</p>
        </div>
      </div>
    </div>
  </AnimatedBlock>

  <!-- How collaboration works -->
  <AnimatedBlock client:load delay={0.6}>
    <div class="mt-4 p-6 md:p-8" style="border: var(--border-brutal); box-shadow: var(--shadow-brutal); background-color: var(--color-bg);">
      <p class="text-xs font-bold uppercase tracking-widest mb-2" style="color: var(--color-blue-deep);">Ako prebieha spolupráca</p>
      <div class="grid gap-3 md:gap-4 md:grid-cols-3 mt-4">
        <div class="p-4" style="border: var(--border-brutal); background: #fff;">
          <p class="text-sm font-bold">1) Audit a cieľ</p>
          <p class="text-sm mt-1" style="opacity: 0.75;">20-min call, mapovanie bottleneckov a definovanie výsledku.</p>
        </div>
        <div class="p-4" style="border: var(--border-brutal); background: #fff;">
          <p class="text-sm font-bold">2) Nasadenie pilotu</p>
          <p class="text-sm mt-1" style="opacity: 0.75;">Setup hlasového flowu, routing, testovanie a fixy v reálnej prevádzke.</p>
        </div>
        <div class="p-4" style="border: var(--border-brutal); background: #fff;">
          <p class="text-sm font-bold">3) Iterácia podľa dát</p>
          <p class="text-sm mt-1" style="opacity: 0.75;">Ladenie promptov a procesu podľa reálnych hovorov a potrieb tímu.</p>
        </div>
      </div>
    </div>
  </AnimatedBlock>

  <!-- Mini FAQ -->
  <AnimatedBlock client:load delay={0.65}>
    <div class="mt-4 p-6 md:p-8" style="border: var(--border-brutal); box-shadow: var(--shadow-brutal); background-color: var(--color-bg);">
      <p class="text-xs font-bold uppercase tracking-widest mb-3" style="color: var(--color-blue-deep);">Mini FAQ</p>
      <div class="grid gap-3 md:gap-4 md:grid-cols-3">
        <div class="p-4" style="border: var(--border-brutal); background: #fff;">
          <p class="text-sm font-bold">Koľko trvá pilot?</p>
          <p class="text-sm mt-1" style="opacity: 0.75;">Typicky 7–14 dní od úvodného callu po prvé ostré testy.</p>
        </div>
        <div class="p-4" style="border: var(--border-brutal); background: #fff;">
          <p class="text-sm font-bold">Musím meniť celý systém?</p>
          <p class="text-sm mt-1" style="opacity: 0.75;">Nie. Začíname pilotom nad tým, čo už používaš, a napájame to postupne.</p>
        </div>
        <div class="p-4" style="border: var(--border-brutal); background: #fff;">
          <p class="text-sm font-bold">Pre koho je to vhodné?</p>
          <p class="text-sm mt-1" style="opacity: 0.75;">Pre ambulancie a služby, kde hovory a objednávky preťažujú personál.</p>
        </div>
      </div>
    </div>
  </AnimatedBlock>

  <!-- Objections -->
  <AnimatedBlock client:load delay={0.68}>
    <div class="mt-4 p-6 md:p-8" style="border: var(--border-brutal); box-shadow: var(--shadow-brutal); background-color: var(--color-silver);">
      <p class="text-xs font-bold uppercase tracking-widest mb-3" style="color: var(--color-blue-deep);">Časté obavy</p>
      <div class="grid gap-3 md:gap-4 md:grid-cols-3">
        <div class="p-4" style="border: var(--border-brutal); background: var(--color-bg);">
          <p class="text-sm font-bold">„AI bude pôsobiť neosobne.“</p>
          <p class="text-sm mt-1" style="opacity:0.75;">Flow sa ladí na tón vašej ambulancie a realitu tímu.</p>
        </div>
        <div class="p-4" style="border: var(--border-brutal); background: var(--color-bg);">
          <p class="text-sm font-bold">„Nechceme meniť celý systém.“</p>
          <p class="text-sm mt-1" style="opacity:0.75;">Začíname pilotom, bez veľkého zásahu do existujúceho stacku.</p>
        </div>
        <div class="p-4" style="border: var(--border-brutal); background: var(--color-bg);">
          <p class="text-sm font-bold">„Nebudeme mať čas to riešiť.“</p>
          <p class="text-sm mt-1" style="opacity:0.75;">Implementácia ide v krátkych krokoch s jasným ownerom a výsledkom.</p>
        </div>
      </div>
    </div>
  </AnimatedBlock>

  <!-- Final CTA -->
  <AnimatedBlock client:load delay={0.7}>
    <div class="mt-4 p-6 md:p-8 flex flex-col md:flex-row md:items-center md:justify-between gap-4" style="border: var(--border-brutal); box-shadow: var(--shadow-brutal); background-color: #FF3EA5;">
      <div>
        <p class="text-xs font-bold uppercase tracking-widest text-white opacity-80">Next step</p>
        <h3 class="text-2xl md:text-3xl font-bold text-white leading-tight mt-1">Do 20 minút zistíš, či má pilot pre tvoju prevádzku reálny ROI.</h3>
      </div>
      <div class="flex flex-col items-start gap-3 w-full md:w-auto">
        <div class="flex flex-wrap gap-3">
          <BrutalistButton href="https://cal.com/xvadur" variant="white" size="md" target="_blank">
            Rezervovať call
          </BrutalistButton>
          <BrutalistButton href="mailto:adam@xvadur.com" variant="black" size="md">
            Napísať e-mail
          </BrutalistButton>
        </div>
        <p class="text-xs text-white/85 font-medium">CTA varianty: „Rezervovať call“ / „Chcem pilot audit“</p>
      </div>
    </div>
  </AnimatedBlock>
</section>

<style>
  @media (max-width: 768px) {
    .hero-grid {
      grid-template-columns: 1fr !important;
    }
    .hero-grid > div {
      grid-column: span 1 !important;
    }
    .trust-grid {
      grid-template-columns: 1fr !important;
    }
  }
  @media (min-width: 769px) and (max-width: 1024px) {
    .hero-grid {
      grid-template-columns: 1fr 1fr !important;
    }
    .trust-grid {
      grid-template-columns: 1fr 1fr 1fr !important;
    }
  }
</style>
