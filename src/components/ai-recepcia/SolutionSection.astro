---
const features = [
  { icon: "🕐", title: "24/7 dostupnosť", desc: "Pacienti sa dovolia aj mimo ordinačných hodín" },
  { icon: "📅", title: "Automatické objednávanie", desc: "Priamo do kalendára, bez manuálneho prepisu" },
  { icon: "🔀", title: "Triáž hovorov", desc: "Urgentné ide na vás, bežné vyrieši AI" },
  { icon: "🌍", title: "Multijazyčnosť", desc: "SK, EN, DE, HU" },
  { icon: "💬", title: "Web widget", desc: "Objednávanie aj cez web" },
  { icon: "📱", title: "SMS pripomienky", desc: "Menej no-show termínov" },
];
---
<section id="riesenie" class="max-w-7xl mx-auto px-6 pb-12 jozo-fade-in" style="animation-delay: 110ms;">
  <div class="grid gap-3 md:grid-cols-2 lg:grid-cols-3">
    <div class="lg:col-span-3 p-8 flex flex-col md:flex-row items-start md:items-center justify-between gap-4"
      style="border: var(--border-brutal); box-shadow: var(--shadow-brutal); background-color: var(--color-blue);">
      <div>
        <p class="text-xs font-bold uppercase tracking-widest mb-1 text-white opacity-80">Riešenie</p>
        <h2 class="text-3xl font-light text-white">AI recepcia, ktorá pracuje 24/7</h2>
        <p class="text-white font-light mt-1" style="opacity: 0.85;">Zdvihne hovor, objedná pacienta a odpovie na bežné otázky.</p>
      </div>
    </div>
    {features.map(f => (
      <div class="p-8 jozo-press-card" style="border: var(--border-brutal); box-shadow: var(--shadow-brutal); background-color: var(--color-bg);">
        <span class="text-3xl mb-3 block">{f.icon}</span>
        <h3 class="text-base font-semibold mb-1">{f.title}</h3>
        <p class="text-sm font-light" style="opacity: 0.7;">{f.desc}</p>
      </div>
    ))}
  </div>
</section>
