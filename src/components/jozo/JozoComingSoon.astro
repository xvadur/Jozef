---
import BrutalistButton from "../ui/BrutalistButton.astro";
---
<section class="max-w-7xl mx-auto px-6 pb-12 jozo-fade-in" style="animation-delay: 260ms;">
  <div class="p-10 flex flex-col md:flex-row items-start md:items-center justify-between gap-6"
    style="border: var(--border-brutal); box-shadow: var(--shadow-brutal); background-color: var(--color-silver);">
    <div>
      <p class="text-xs font-bold uppercase tracking-widest mb-2" style="color: var(--color-blue-deep);">Next step</p>
      <h2 class="text-3xl font-light mb-2">Chceš Joža ako operátora pre svoju firmu?</h2>
      <p class="text-base font-light" style="opacity: 0.7;">
        Urobíme krátky audit, nastavíme scope a navrhneme pilot podľa tvojej reality.
      </p>
    </div>
    <div class="flex flex-col gap-3">
      <BrutalistButton href="https://cal.com/xvadur" variant="black" size="lg" target="_blank" class="jozo-cta-pulse">
        Rezervovať Jožo audit →
      </BrutalistButton>
      <a href="mailto:adam@xvadur.com" class="text-xs font-bold uppercase tracking-wider" style="color: var(--color-blue-deep);">alebo napíš na adam@xvadur.com</a>
    </div>
  </div>
</section>
