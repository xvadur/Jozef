---
const capabilities = [
  {
    icon: "📋",
    title: "Tasky & Priority",
    desc: "Premieňam chat intent na konkrétne kroky, poradie a exekučné bloky.",
    detail: "Rozsekám cieľ na realizovateľné kroky, navrhnem poradie podľa dopadu a dám jasný next action bez balastu.",
  },
  {
    icon: "🧠",
    title: "Pamäť & Kontext",
    desc: "Držím kontinuitu medzi dňami cez memory stack a CRM follow-upy.",
    detail: "Udržiavam čo bolo dohodnuté, čo je rozbehnuté a čo horí, aby sa nestrácal kontext medzi sessionmi.",
  },
  {
    icon: "🔌",
    title: "Integrácie",
    desc: "Pracujem naprieč Google, Linear, Airtable, Cloudflare, GitHub a n8n.",
    detail: "Prepájam systémy do jedného toku: od zadania cez update až po finálny výstup bez manuálneho prepínania.",
  },
  {
    icon: "📝",
    title: "Briefingy & Reporty",
    desc: "Vyrábam stručné reporty a rozhodovacie podklady použiteľné hneď.",
    detail: "Dostaneš stručné zhrnutie: čo je hotové, čo je bloknuté, čo je ďalší krok a kde je riziko.",
  },
];

const capabilityTrack = [...capabilities, ...capabilities];
---
<section id="co-jozo-robi" class="w-full pb-12 jozo-fade-in" style="animation-delay: 140ms;">
  <div class="max-w-7xl mx-auto px-6">
    <div class="p-6"
      style="border: var(--border-brutal); box-shadow: var(--shadow-brutal); background-color: var(--color-silver);">
      <p class="text-xs font-bold uppercase tracking-widest mb-1" style="color: var(--color-blue-deep);">Čo reálne robím</p>
      <h2 class="text-2xl font-light">Schopnosti</h2>
    </div>
  </div>

  <div class="cap-marquee mt-3">
    <div class="cap-track">
      {capabilityTrack.map((c, i) => (
        <article class="cap-card jozo-card-hover" aria-hidden={i >= capabilities.length ? "true" : "false"}>
          <span class="text-2xl mb-2 block">{c.icon}</span>
          <h3 class="text-base font-semibold mb-2">{c.title}</h3>
          <div class="cap-copy">
            <p class="cap-desc text-sm font-light">{c.desc}</p>
            <p class="cap-detail text-sm">{c.detail}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .cap-marquee {
    width: 100%;
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent 0, black 6%, black 94%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, transparent 0, black 6%, black 94%, transparent 100%);
  }

  .cap-track {
    display: flex;
    gap: 0.75rem;
    width: max-content;
    padding: 0 1.5rem;
    animation: capScroll 34s linear infinite;
  }

  .cap-marquee:hover .cap-track {
    animation-play-state: paused;
  }

  .cap-card {
    width: min(72vw, 300px);
    padding: 1.25rem;
    border: var(--border-brutal);
    box-shadow: var(--shadow-brutal);
    background-color: var(--color-bg);
    flex: 0 0 auto;
    min-height: 170px;
  }

  .cap-copy {
    position: relative;
    min-height: 72px;
  }

  .cap-desc,
  .cap-detail {
    position: absolute;
    inset: 0;
    margin: 0;
    transition: opacity 180ms ease, transform 180ms ease;
  }

  .cap-desc {
    opacity: 0.78;
    transform: translateY(0);
  }

  .cap-detail {
    opacity: 0;
    transform: translateY(4px);
    font-weight: 400;
    line-height: 1.45;
  }

  .cap-card:hover .cap-desc,
  .cap-card:focus-within .cap-desc {
    opacity: 0;
    transform: translateY(-4px);
  }

  .cap-card:hover .cap-detail,
  .cap-card:focus-within .cap-detail {
    opacity: 0.95;
    transform: translateY(0);
  }

  @keyframes capScroll {
    from { transform: translateX(0); }
    to { transform: translateX(calc(-50% - 0.375rem)); }
  }

  @media (max-width: 768px) {
    .cap-track { animation-duration: 26s; }
    .cap-card { width: min(82vw, 280px); padding: 1.1rem; min-height: 165px; }
    .cap-copy { min-height: 80px; }
    .cap-desc { opacity: 0; transform: translateY(-4px); }
    .cap-detail { opacity: 0.95; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .cap-track { animation: none; }
    .cap-marquee { overflow-x: auto; mask-image: none; -webkit-mask-image: none; }
  }
</style>
