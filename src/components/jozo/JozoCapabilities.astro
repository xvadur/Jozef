---
const capabilities = [
  { icon: "📋", title: "Tasky & Priority", desc: "Premieňam chat intent na konkrétne kroky, poradie a exekučné bloky." },
  { icon: "🧠", title: "Pamäť & Kontext", desc: "Držím kontinuitu medzi dňami cez memory stack a CRM follow-upy." },
  { icon: "🔌", title: "Integrácie", desc: "Pracujem naprieč Google, Linear, Airtable, Cloudflare, GitHub a n8n." },
  { icon: "📝", title: "Briefingy & Reporty", desc: "Vyrábam stručné reporty a rozhodovacie podklady použiteľné hneď." },
];

const capabilityTrack = [...capabilities, ...capabilities];
---
<section id="co-jozo-robi" class="w-full pb-12 jozo-fade-in" style="animation-delay: 140ms;">
  <div class="max-w-7xl mx-auto px-6">
    <div class="p-6"
      style="border: var(--border-brutal); box-shadow: var(--shadow-brutal); background-color: var(--color-silver);">
      <p class="text-xs font-bold uppercase tracking-widest mb-1" style="color: var(--color-blue-deep);">Čo reálne robím</p>
      <h2 class="text-2xl font-light">Schopnosti</h2>
    </div>
  </div>

  <div class="cap-marquee mt-3">
    <div class="cap-track">
      {capabilityTrack.map((c, i) => (
        <article class="cap-card jozo-card-hover" aria-hidden={i >= capabilities.length ? "true" : "false"}>
          <span class="text-3xl mb-4 block">{c.icon}</span>
          <h3 class="text-lg font-semibold mb-2">{c.title}</h3>
          <p class="text-sm font-light" style="opacity: 0.72;">{c.desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .cap-marquee {
    width: 100%;
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent 0, black 6%, black 94%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, transparent 0, black 6%, black 94%, transparent 100%);
  }

  .cap-track {
    display: flex;
    gap: 0.75rem;
    width: max-content;
    padding: 0 1.5rem;
    animation: capScroll 34s linear infinite;
  }

  .cap-marquee:hover .cap-track {
    animation-play-state: paused;
  }

  .cap-card {
    width: min(82vw, 360px);
    padding: 2rem;
    border: var(--border-brutal);
    box-shadow: var(--shadow-brutal);
    background-color: var(--color-bg);
    flex: 0 0 auto;
  }

  @keyframes capScroll {
    from { transform: translateX(0); }
    to { transform: translateX(calc(-50% - 0.375rem)); }
  }

  @media (max-width: 768px) {
    .cap-track { animation-duration: 26s; }
    .cap-card { width: min(86vw, 320px); padding: 1.5rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .cap-track { animation: none; }
    .cap-marquee { overflow-x: auto; mask-image: none; -webkit-mask-image: none; }
  }
</style>
