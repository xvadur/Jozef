---
const integrations = [
  { iconUrl: "https://cdn.simpleicons.org/openai/412991", name: "OpenClaw" },
  { iconUrl: "https://cdn.simpleicons.org/telegram/26A5E4", name: "Telegram" },
  { iconUrl: "https://cdn.simpleicons.org/cloudflare/F38020", name: "Cloudflare" },
  { iconUrl: "https://cdn.simpleicons.org/linear/5E6AD2", name: "Linear" },
  { iconUrl: "https://cdn.simpleicons.org/airtable/18BFFF", name: "Airtable" },
  { iconUrl: "https://cdn.simpleicons.org/n8n/EA4B71", name: "n8n" },
  { iconUrl: "https://cdn.simpleicons.org/supabase/3ECF8E", name: "Supabase" },
  { iconUrl: "https://cdn.simpleicons.org/googlecalendar/4285F4", name: "Google Calendar" },
  { iconUrl: "https://cdn.simpleicons.org/gmail/EA4335", name: "Gmail" },
  { iconUrl: "https://cdn.simpleicons.org/googlemaps/4285F4", name: "Google Places" },
  { iconUrl: "https://cdn.simpleicons.org/elevenlabs/000000", name: "ElevenLabs" },
  { iconUrl: "https://cdn.simpleicons.org/openrouter/7C3AED", name: "OpenRouter" },
  { iconUrl: "https://cdn.simpleicons.org/github/181717", name: "GitHub" },
];

const track = [...integrations, ...integrations];
---

<section id="co-jozo-robi" class="max-w-7xl mx-auto px-6 pb-12 jozo-fade-in" style="animation-delay: 140ms;">
  <div class="p-6" style="border: var(--border-brutal); box-shadow: var(--shadow-brutal); background-color: var(--color-silver);">
    <p class="text-xs font-bold uppercase tracking-widest mb-1" style="color: var(--color-blue-deep);">Aktívne integrácie</p>
    <h2 class="text-2xl font-light tracking-tight">Jožo pracuje naprieč stackom</h2>
    <p class="text-sm mt-2" style="opacity:0.72;">API-enabled nástroje, ktoré aktuálne používame.</p>
  </div>

  <div class="integration-marquee mt-4" aria-label="Aktívne integrácie">
    <div class="integration-track">
      {track.map((item, i) => (
        <div class="integration-chip" aria-hidden={i >= integrations.length ? "true" : "false"}>
          <img class="integration-icon" src={item.iconUrl} alt={`${item.name} logo`} loading="lazy" decoding="async" />
          <span class="integration-name">{item.name}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .integration-marquee {
    width: 100%;
    overflow: hidden;
    border: var(--border-brutal);
    box-shadow: var(--shadow-brutal);
    background: var(--color-bg);
    padding: 0.95rem 0;
    mask-image: linear-gradient(to right, transparent 0, black 3%, black 97%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, transparent 0, black 3%, black 97%, transparent 100%);
  }

  .integration-track {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    width: max-content;
    padding: 0 1.5rem;
    animation: integrationsScroll 36s linear infinite;
  }

  .integration-marquee:hover .integration-track { animation-play-state: paused; }

  .integration-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.52rem 0.85rem;
    border: 2px solid var(--color-black);
    box-shadow: var(--shadow-brutal-sm);
    background: #fff;
    flex: 0 0 auto;
  }

  .integration-icon {
    width: 16px;
    height: 16px;
    object-fit: contain;
    border-radius: 3px;
    flex: 0 0 auto;
  }

  .integration-name {
    font-size: 0.74rem;
    text-transform: uppercase;
    letter-spacing: 0.055em;
    font-weight: 700;
    color: var(--color-text);
    white-space: nowrap;
  }

  @keyframes integrationsScroll {
    from { transform: translateX(0); }
    to { transform: translateX(calc(-50% - 0.35rem)); }
  }

  @media (max-width: 768px) {
    .integration-track { animation-duration: 28s; }
    .integration-name { font-size: 0.72rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .integration-track { animation: none; }
    .integration-marquee {
      overflow-x: auto;
      mask-image: none;
      -webkit-mask-image: none;
    }
  }
</style>
