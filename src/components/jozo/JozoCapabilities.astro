---
const integrations = [
  {
    icon: "🧠",
    name: "OpenClaw",
    detail: "Core runtime orchestrace, pamäť a tool routing.",
  },
  {
    icon: "📅",
    name: "Google Calendar",
    detail: "Čítanie/plánovanie udalostí a booking logika.",
  },
  {
    icon: "✉️",
    name: "Gmail",
    detail: "Inbox workflowy, drafty a odpovede.",
  },
  {
    icon: "📈",
    name: "Linear",
    detail: "Issue tracking, delivery checkpointy a execution flow.",
  },
  {
    icon: "🗂️",
    name: "Airtable",
    detail: "CRM-like tabuľky a bezpečné upserty cez API.",
  },
  {
    icon: "☁️",
    name: "Cloudflare",
    detail: "DNS, SSL, zones a infra nastavenia.",
  },
  {
    icon: "🐙",
    name: "GitHub",
    detail: "Repo zmeny, commity, push a release workflow.",
  },
  {
    icon: "🔄",
    name: "n8n",
    detail: "Automatizácie, workflow runy a exekúcia triggerov.",
  },
  {
    icon: "🧮",
    name: "Supabase",
    detail: "DB operácie, SQL, vektory a storage.",
  },
  {
    icon: "🔎",
    name: "Brave Search",
    detail: "Realtime web research a content extraction.",
  },
  {
    icon: "💬",
    name: "Telegram",
    detail: "Skupiny, topicy, notifikácie a command loop.",
  },
];

const track = [...integrations, ...integrations];
---

<section id="co-jozo-robi" class="max-w-7xl mx-auto px-6 pb-12 jozo-fade-in" style="animation-delay: 140ms;">
  <div
    class="p-6"
    style="border: var(--border-brutal); box-shadow: var(--shadow-brutal); background-color: var(--color-silver);"
  >
    <p class="text-xs font-bold uppercase tracking-widest mb-1" style="color: var(--color-blue-deep);">
      Integrácie s API prístupom
    </p>
    <h2 class="text-2xl font-light tracking-tight">Jožo pracuje naprieč stackom</h2>
    <p class="text-sm mt-2" style="opacity:0.72;">Hover = detail integrácie · pás sa pri hover zastaví.</p>
  </div>

  <div class="integration-marquee mt-4">
    <div class="integration-track">
      {track.map((item, i) => (
        <div class="integration-chip" aria-hidden={i >= integrations.length ? "true" : "false"}>
          <span class="integration-icon" aria-hidden="true">{item.icon}</span>
          <span class="integration-name">{item.name}</span>
          <div class="integration-detail">{item.detail}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .integration-marquee {
    width: 100%;
    overflow: hidden;
    border: var(--border-brutal);
    box-shadow: var(--shadow-brutal);
    background: var(--color-bg);
    padding: 0.95rem 0;
    mask-image: linear-gradient(to right, transparent 0, black 3%, black 97%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, transparent 0, black 3%, black 97%, transparent 100%);
  }

  .integration-track {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    width: max-content;
    padding: 0 1.5rem;
    animation: integrationsScroll 36s linear infinite;
  }

  .integration-marquee:hover .integration-track {
    animation-play-state: paused;
  }

  .integration-chip {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.52rem 0.85rem;
    border: 2px solid var(--color-black);
    box-shadow: var(--shadow-brutal-sm);
    background: #fff;
    flex: 0 0 auto;
  }

  .integration-icon {
    font-size: 0.95rem;
    line-height: 1;
  }

  .integration-name {
    font-size: 0.74rem;
    text-transform: uppercase;
    letter-spacing: 0.055em;
    font-weight: 700;
    color: var(--color-text);
    white-space: nowrap;
  }

  .integration-detail {
    position: absolute;
    left: 0;
    bottom: calc(100% + 8px);
    width: 230px;
    padding: 0.6rem 0.7rem;
    border: var(--border-brutal);
    box-shadow: var(--shadow-brutal-sm);
    background: var(--color-silver);
    color: var(--color-text);
    font-size: 0.75rem;
    line-height: 1.35;
    opacity: 0;
    transform: translateY(4px);
    pointer-events: none;
    transition: opacity 140ms ease, transform 140ms ease;
    z-index: 10;
  }

  .integration-chip:hover .integration-detail {
    opacity: 1;
    transform: translateY(0);
  }

  @keyframes integrationsScroll {
    from { transform: translateX(0); }
    to { transform: translateX(calc(-50% - 0.35rem)); }
  }

  @media (max-width: 768px) {
    .integration-track { animation-duration: 28s; }
    .integration-name { font-size: 0.72rem; }
    .integration-detail { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .integration-track { animation: none; }
    .integration-marquee {
      overflow-x: auto;
      mask-image: none;
      -webkit-mask-image: none;
    }
  }
</style>
